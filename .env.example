# Momentum Intelligence — Environment Variables
# Kopieer naar .env en vul in. Commit NOOIT .env naar git.
# .env staat al in .gitignore.

# ── DATA BRONNEN ──────────────────────────────────────────────────────────────

# Finnhub API key — vereist voor nieuws/catalyst data (fase 2.2)
# Gratis tier: 60 calls/min. Haal op via https://finnhub.io
FINNHUB_API_KEY=

# StockTwits — vereist voor social acceleration (fase 2.3)
# Gratis voor persoonlijk gebruik. https://api.stocktwits.com
STOCKTWITS_ACCESS_TOKEN=

# ── CACHE CONFIGURATIE ────────────────────────────────────────────────────────

# Cache aan/uit (standaard: true)
CACHE_ENABLED=true

# Cache TTL in seconden tijdens regular market hours (standaard: 60)
CACHE_TTL_SECONDS=60

# ── LOGGING ───────────────────────────────────────────────────────────────────

# Log niveau: DEBUG, INFO, WARNING, ERROR (standaard: INFO)
LOG_LEVEL=INFO

# Log formaat: text of json (standaard: text)
LOG_FORMAT=text

# ── API SERVER ────────────────────────────────────────────────────────────────

# Server host (standaard: 127.0.0.1 — alleen lokaal bereikbaar)
API_HOST=127.0.0.1

# Server port (standaard: 8000)
API_PORT=8000

# ── SCORE ENGINE ──────────────────────────────────────────────────────────────

# Maximaal aantal tickers per batch request (standaard: 10)
BATCH_MAX_TICKERS=10
